---
import { getCollection } from "astro:content";

import BaseLayout from "../layouts/BaseLayout.astro";
import Item from "../components/Item.astro";
import Path from "../components/Path.astro";
import Tags from "../components/Tags.astro";
import Summary from "../components/Summary.astro";

const allNotes = await getCollection("notes");
---

<BaseLayout>

  <div class="content-container">
    <div class="page-title">Notes</div>

    <ul class="unordered-list">
      {
        allNotes.map((note) => (
          <Item url={`/notes/${note.slug}/`} title={note.data.title}>
            <Path value={`/notes/${note.slug}/`} slot="path" />
            <Summary text={note.data.summary} slot="summary" />
            <Tags items={note.data.tags} slot="tags" />
          </Item>
        ))
      }
    </ul>
  </div>

</BaseLayout>