---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Summary from '../../components/Summary/Item.astro';

export async function getStaticPaths() {
  
  const allContent = await Astro.glob('../../content/**/*.{md,mdx}');
  const uniqueTags = [...new Set(allContent.map( content => content.frontmatter.tags ).flat())];

  // console.log(`uniqueTags: ${JSON.stringify(uniqueTags,null,2)}`);

  return uniqueTags.map((tag) => {

    const filteredContent = allContent.filter((note) => note.frontmatter.tags.includes(tag));

    // console.log(`Filtered NOTES: ${JSON.stringify(filteredContent,null,2)}`);
    
    const annotatedResults = filteredContent.map( (item) => {
      const nextResult = { path: "", category: "", ...item};
      const contentPath = item.file.substring(item.file.indexOf("content"));
      let filePath = contentPath;
      let itemCategory = "Content";
      if(contentPath.indexOf("notes") >= 0) {
        itemCategory = "Notes";
        filePath = contentPath.substring(contentPath.indexOf("notes"));
      }
      if (contentPath.indexOf("solutions") >= 0) {
        itemCategory = "Solutions";
        filePath = contentPath.substring(contentPath.indexOf("solutions"));
      }
      nextResult.category = itemCategory;
      nextResult.path = filePath.substring(0,filePath.lastIndexOf('.')).replace(/index/g, ""); 
      return nextResult;
    })

    // console.log(`FIL: ${JSON.stringify(annotatedResults,null,2)}`);

    return {
      params: { tag: tag },
      props: { 
        results: annotatedResults,
        // solutionsResults: filteredSolutions,
       },
      }
  });


  // const allSolutions = await Astro.glob('../../content/solutions/**/*.{md,mdx}');
  // const solutionsTags = [...new Set(allSolutions.map((solution) => solution.frontmatter.tags).flat())];
  // const filteredSolutions = allSolutions.filter((solution) => solution.frontmatter.tags.includes(tag));


  console.log(`RESULTS: ${JSON.stringify(notesResults.length,null,2)}`);


  return notesResults;

}

const { tag } = Astro.params;
const { results } = Astro.props;
---
<BaseLayout pagetTitle="Tags">

  <div class="page-title">{`Tagged: "${tag}"`}</div>
    <div class="content-container">
      { results.map( (result) => (
            <ul class="unordered-list">
              <Summary path={`/${result.path}`} frontmatter={result.frontmatter} tagged={tag} category={result.category}/>
            </ul>
          )
        )
      }
    </div>

</BaseLayout>